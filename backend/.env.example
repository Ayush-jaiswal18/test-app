# ─── Server ───────────────────────────────────────────────
PORT=5000

# ─── MongoDB ──────────────────────────────────────────────
# Local:
# MONGO_URI=mongodb://127.0.0.1:27017/test_app
# Atlas (replace with your connection string):
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/test_app?retryWrites=true&w=majority

# ─── Auth ─────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string

# ─── Judge0 (Code Execution) ──────────────────────────────
JUDGE0_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_KEY=your_rapidapi_key_here

# ─── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (production URL goes here)
# Example: FRONTEND_URL=https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173
